#include <Arduino.h>

// define constants for latch pin, clock pin, and data pin
int latchPin = 8;
int clockPin = 12;
int dataPin = 11;

// create a variable (shadow register) to store the full 8-bit output state
byte shadow = 0b00000000; 
byte upperMask = 0b00001111;
byte lowerMask = 0b11110000;

// create an array holding the 4 motor step patterns (1000, 0100, 0010, 0001)
byte motorStep[4] = {0b1000, 0b0100, 0b0010, 0b0001};


void writeRegister() {

  // set latch LOW to prepare for new data
  digitalWrite(latchPin, LOW);
  // shift out the 8-bit shadow value to the shift register
  shiftOut(dataPin, clockPin, MSBFIRST, shadow);
  // set latch HIGH to update the outputs
  digitalWrite(latchPin, HIGH);
}



void setMotorState(byte motorBits) {

  // clear the upper 4 bits (Q4–Q7) in the shadow variable
  // (this removes previous motor signals but keeps LED bits)
  shadow = shadow & upperMask;
  // shift the motorBits left by 4 so they line up with Q4–Q7
  motorBits = motorBits << 4;
  // combine the shifted motor bits with the shadow variable
  // (this inserts the new motor state without affecting Q0–Q3)
  shadow = shadow | motorBits;
  // store the result back into the shadow variable
  writeRegister();
  // send the updated shadow value to the shift register

}



void setup() {

  // set latch pin as OUTPUT
  pinMode(latchPin, OUTPUT);
  // set clock pin as OUTPUT
  pinMode(clockPin, OUTPUT);
  // set data pin as OUTPUT
  pinMode(dataPin, OUTPUT);
  // initialise the shift register by sending the shadow value (all outputs OFF)
  writeRegister();
}


void loop() {

  for (int i = 0; i < 4; i++ ){
    setMotorState(motorStep[i]);
    delay(10);


  }

}